# Copy to .env and fill in values.
# On Vercel: set these in Project Settings → Environment Variables.

# Option 1: Single connection string (Vercel Postgres, Neon, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/gearguard?sslmode=require

# Option 2: Individual vars (local or custom Postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=gearguard

# Optional: override CORS / site URL
# SITE_URL=https://oddo-x-adani-hackaton.vercel.app
